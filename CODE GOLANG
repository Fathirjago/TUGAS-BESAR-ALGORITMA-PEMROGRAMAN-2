func searchid(P tabpas, np int) int {
	var found, mid, left, right, cariid int
	fmt.Print("Masukkan ID pasien yang ingin dicari: ")
	fmt.Scan(&cariid)
	left = 0
	right = np - 1
	found = -1
	for left <= right && found == -1 {
		mid = (left + right) / 2
		if cariid > P[mid].idPasien {
			left = mid + 1
		} else if cariid < P[mid].idPasien {
			right = mid - 1
		} else {
			found = mid
		}
	}
	return found
}

func searcnama(P tabpas, np int) int {
	var ketemu, i int
	var carinama string
	fmt.Print("Masukkan nama pasien yang ingin dicari: ")
	fmt.Scan(&carinama)
	ketemu = -1
	i = 0
	for ketemu == -1 && i < np {
		if carinama == P[i].nama {
			ketemu = i
		}
		i++
	}
	return ketemu
}

func statistik(K tabKun, L tablay, nk, nl int) {
	var i, banyaklay, banyakkun, max, j, caritgl int
	var layfav, layfavall string
	var banyaklayall, maxall, k, l int
	max = 0
	banyakkun = 0
	banyaklay = 0
	maxall = 0
	banyaklayall = 0
	for k = 0; k < nl; k++ {
		banyaklayall = 0
		for l = 0; l < nk; l++ {
			if K[l].idLayanan == L[k].idLayanan {
				banyaklayall++
			}
		}
		if banyaklayall > maxall {
			maxall = banyaklayall
			layfavall = L[k].jenisLayanan
		}
	}
	fmt.Println("\n------------------------------------------------")
	fmt.Println("STATISTIK KLINIK ALLTIME")
	fmt.Println("------------------------------------------------")
	fmt.Printf("Jumlah kunjungan alltime: %d kunjungan\n", nk)
	fmt.Println("Layanan favorit alltime :", layfavall)
	fmt.Println("------------------------------------------------")
	fmt.Println("Masukkan tanggal kunjungan (YYYYMMDD): ")
	fmt.Scan(&caritgl)
	for i = 0; i < nk; i++ {
		if K[i].tanggal == caritgl {
			banyakkun++
		}
	}
	for i = 0; i < nl; i++ {
		banyaklay = 0
		for j = 0; j < nk; j++ {
			if K[j].idLayanan == L[i].idLayanan && K[j].tanggal == caritgl {
				banyaklay++
			}
		}
		if banyaklay > max {
			max = banyaklay
			layfav = L[i].jenisLayanan
		}
	}
	if max > 0 {
		fmt.Println("\n------------------------------------------------")
		fmt.Printf("STATISTIK HARIAN KLINIK TANGGAL: %d \n", caritgl)
		fmt.Println("------------------------------------------------")
		fmt.Printf("Jumlah kunjungan: %d kunjungan\n", banyakkun)
		fmt.Println("Layanan favorit :", layfav)
		fmt.Println("------------------------------------------------")
	} else {
		fmt.Printf("Tidak ada kunjungan pada tanggal: %d.\n", caritgl)
	}
}
