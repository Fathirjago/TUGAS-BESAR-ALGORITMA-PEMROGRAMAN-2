func uruttanggal(K *tabKun, P *tabpas, np int) {
	var i, pass int
	var tempkun Kunjungan
	var temppas pasien
	pass = 1
	for pass <= np-1 {
		tempkun = K[pass]
		temppas = P[pass]
		i = pass
		for i > 0 && tempkun.tanggal > K[i-1].tanggal {
			K[i] = K[i-1]
			P[i] = P[i-1]
			i--
		}
		K[i] = tempkun
		P[i] = temppas
		pass++
	}
}

func urutbiaya(K *tabKun, P *tabpas, np int) {
	var pass, i, idx int
	var tempkun Kunjungan
	var temppas pasien
	pass = 1
	for pass <= np-1 {
		idx = pass - 1
		i = pass
		for i < np {
			if K[idx].biaya < K[i].biaya {
				idx = i
			}
			i++
		}
		tempkun = K[pass-1]
		temppas = P[pass-1]
		K[pass-1] = K[idx]
		P[pass-1] = P[idx]
		K[idx] = tempkun
		P[idx] = temppas
		pass++
	}
}

