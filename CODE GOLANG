				fmt.Printf("%-15d %-22s Rp. %-12.2f\n", L[i].idLayanan, L[i].jenisLayanan, L[i].hargaLayanan)
			}
			fmt.Println("--------------------------------------------------")
			for ketemu == false {
				fmt.Print("ID layanan: ")
				fmt.Scan(&inputlay)
				i = 0
				for i < nl && ketemu == false {
					if inputlay == L[i].idLayanan {
						ketemu = true
						K[*np].biaya = L[i].hargaLayanan
					}
					i++
				}
				if ketemu == false {
					fmt.Println("ID layanan tidak valid, harap isi layanan yang ada!")
				}
			}
			P[*np].idPasien = *np + 1
			K[*np].idPasien = P[*np].idPasien
			K[*np].idLayanan = inputlay
			K[*np].idTransaksi = *np + 111111111111
			*np = *np + 1
			fmt.Println("Pasien berhasil di tambahkan")
		}
		fmt.Println("Jumlah pasien:", *np)
		fmt.Println("1. Tambah Pasien")
		fmt.Println("2. Kembali")
		fmt.Print("Pilih (angka): ")
		fmt.Scan(&pilihpas)
		if pilihpas == 1 {
			addPasien(P, K, L, np, nl)
		}
	} else {
		fmt.Println("Data pasien sudah penuh!")
	}
}

func delPasien(P *tabpas, K *tabKun, np *int) {
	var i, idpas, j int
	var ketemu bool
	i = 0
	ketemu = false
	fmt.Print("Masukkan ID pasien yang ingin dihapus: ")
	fmt.Scan(&idpas)
	for i < *np {
		j = i
		if P[i].idPasien == idpas {
			ketemu = true
			for j < *np-1 {
				K[j] = K[j+1]
				P[j] = P[j+1]
				j++
			}
			*np = *np - 1
			i--
		}
		i++
	}
	if ketemu == true {
		fmt.Println("Pasien berhasil dihapus")
	} else {
		fmt.Println("ID pasien tidak ditemukan")
	}
}

